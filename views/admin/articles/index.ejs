 <div id="admin-content">
      <div class="container">
          <div class="row">
              <div class="col-md-10">
                  <h1 class="admin-heading"><i class="fa fa-file-text"></i> All Articles</h1>
              </div>
              <div class="col-md-2">
                  <a class="add-new" href="/admin/add-article">Add New Article</a>
              </div>
              <div class="col-md-12">
                <div id="articlesTable"></div>  
              </div>
          </div>
      </div>
  </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/tabulator-tables@6.0.0/dist/js/tabulator.min.js"></script>

<script>
  const tableData = <%- JSON.stringify(typeof articles !== 'undefined' ? articles : []) %>;

  new Tabulator("#articlesTable", {
    data: tableData,
    layout: "fitColumns",
    pagination: true,
    paginationSize: 10,
    paginationSizeSelector: [5, 10, 25, 50, 100],
    movableColumns: false,
    columns: [
      { title: "S.No.", field: "serial", width: 90, hozAlign: "center" },
      { title: "Title", field: "title", headerFilter: "input" },
      { title: "Category", field: "category.name", headerFilter: "input" },
      { title: "Date", field: "createdAt", headerFilter: "input" ,formatter: function(cell) {
        const date = new Date(cell.getValue());
        const day = date.getDate().toString().padStart(2, '0');
        const month = date.toLocaleString('default', { month: 'long' }).substring(0,3);
        const year = date.getFullYear();
        const time = date.toLocaleTimeString().split(':').slice(0,2).join(':');
        const ampm = date.toLocaleTimeString().split(' ')[1].toUpperCase();
        return `${day}-${month}-${year} ${time} ${ampm}`;
      } },
      { title: "Author", field: "author.fullname", headerFilter: "input" },
      {
        title: "Actions",
        hozAlign: "center",
        width: 180,
        formatter: function(cell) {
          const row = cell.getData();
          return `
            <a href="/admin/update-article/${row._id}" class="btn btn-success btn-sm me-2">Edit</a>
            <button class="btn btn-danger btn-sm delete-article" onclick="deleteArticle('${row._id}')">Delete</button>
          `;
        }
      }
    ]
  });

  async function deleteArticle(id) {
    try {
      if (confirm("Are you sure you want to delete this article?")) {
        const response = await fetch(`/admin/delete-article/${id}`, {
          method: "DELETE"
        });

        if (response.ok) {
          window.location.reload();
        }
      }
    } catch (error) {
      console.log(error);
    }
  }
</script>

<%- contentFor("summernoteCSS")%>
<link href="https://unpkg.com/tabulator-tables@6.0.0/dist/css/tabulator.min.css" rel="stylesheet">
<link href="/css/tabulator_bootstrap5.min.css" rel="stylesheet">